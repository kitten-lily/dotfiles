# Get editor completions based on the config schema
"$schema" = 'https://starship.rs/config-schema.json'

# Sets user-defined palette
palette = "catppuccin_{{ .catppuccinThemeLower }}"

# Prompt
format = """$directory$fill$git_branch$git_status
$os$character"""

right_format = """$time"""

